# ============================================================
# Angular Frontend Environment Variables
# ============================================================
# These are NOT used at runtime — Angular uses src/environments/
# files instead. This file documents the external services needed.
# ============================================================

# Supabase
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=your_supabase_anon_key

# Stripe (not used at runtime — keys are only in Supabase Edge Functions)
# See supabase/.env.example for the keys needed

# App Configuration
PLATFORM_FEE_PERCENTAGE=22
