# ============================================================
# Angular Frontend Environment Variables
# ============================================================
# These are NOT used at runtime — Angular uses src/environments/
# files instead. This file documents the external services needed.
# ============================================================

# Supabase
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=your_supabase_anon_key

# Stripe
STRIPE_PUBLISHABLE_KEY=pk_test_...

# App Configuration
PLATFORM_FEE_PERCENTAGE=35
