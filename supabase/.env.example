# ============================================================
# LOCAL DEVELOPMENT ONLY
# ============================================================
# Copy this file to `supabase/.env` and fill in your values.
# This file is used ONLY by `supabase functions serve` (local).
# Production secrets are set via `supabase secrets set KEY=VALUE`.
# See `supabase/.env.production` for production reference.
# ============================================================

# Stripe API Keys (Get from https://dashboard.stripe.com/test/apikeys)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# Stripe Webhook Secret (Get from `stripe listen --forward-to` output)
STRIPE_WEBHOOK_SECRET=whsec_...

# Application URL (localhost for local dev)
APP_URL=http://localhost:4200

# Platform Fee (percentage — creator keeps 100 minus this)
PLATFORM_FEE_PERCENTAGE=22

# Resend (transactional emails — https://resend.com)
RESEND_API_KEY=re_...
RESEND_FROM_ADDRESS=Convozo <onboarding@resend.dev>

# Local Supabase (from `supabase status` output)
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_ROLE_KEY=your_local_service_role_key
