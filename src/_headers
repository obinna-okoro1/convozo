# Cloudflare Pages response headers
#
# index.html must NEVER be cached — every deploy changes chunk filenames.
# If a stale index.html is served, it references old JS chunks that no longer
# exist, causing "text/html" MIME errors when the browser tries to load them.

# ── Security headers applied to ALL routes ─────────────────────────────────────
/*
  # Prevent this site from being embedded in iframes on other origins (clickjacking)
  X-Frame-Options: SAMEORIGIN
  # Prevent browsers from MIME-sniffing the content-type (MIME confusion attacks)
  X-Content-Type-Options: nosniff
  # Don't leak the full Referrer URL to third-party origins
  Referrer-Policy: strict-origin-when-cross-origin
  # Restrict browser feature access — permit camera/mic (Daily.co calls), deny everything else
  Permissions-Policy: camera=self, microphone=self, payment=(), geolocation=(), usb=(), serial=(), bluetooth=()
  # Force HTTPS for 1 year and include subdomains (requires HTTPS-only deployment — Cloudflare Pages)
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  # XSS auditor hint for legacy browsers (modern browsers ignore it but it doesn't hurt)
  X-XSS-Protection: 1; mode=block
  # Content Security Policy
  # - default-src 'self': only load resources from our own origin by default
  # - script-src 'self' https://js.stripe.com: Angular chunks + Stripe.js CDN (no 'unsafe-inline'
  #   needed — the SW registration script is an external file, not inline)
  # - style-src 'self' 'unsafe-inline': Tailwind injects inline styles at runtime
  # - font-src https://fonts.gstatic.com: Google Fonts static font files
  # - img-src 'self' data: blob: https:: profile images, avatars, data URIs
  # - connect-src: Supabase (both prod+staging), Stripe, Paystack, Daily.co, push endpoints,
  #   Google Fonts CSS API (fonts.googleapis.com resolves font requests)
  # - frame-src https://checkout.stripe.com: Stripe may open in a frame on some flows
  # - object-src 'none': block Flash and legacy plugins
  # - worker-src 'self': allow service worker registration from our own origin
  # - base-uri 'self': prevent base-tag hijacking
  # - form-action 'self': prevent forms being submitted to external origins
  Content-Security-Policy: default-src 'self'; script-src 'self' https://js.stripe.com; style-src 'self' 'unsafe-inline'; font-src https://fonts.gstatic.com; img-src 'self' data: blob: https:; connect-src 'self' https://*.supabase.co https://api.stripe.com https://checkout.stripe.com https://api.paystack.co https://*.daily.co wss://*.supabase.co https://fonts.googleapis.com; frame-src https://checkout.stripe.com; object-src 'none'; worker-src 'self'; base-uri 'self'; form-action 'self'

/index.html
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache

# Hashed JS/CSS chunks are immutable — safe to cache forever.
# Angular appends a content hash to every chunk filename, so stale files
# are never an issue here.
/*.js
  Cache-Control: public, max-age=31536000, immutable

/*.css
  Cache-Control: public, max-age=31536000, immutable

# Service worker must not be cached so updates are picked up immediately.
/sw.js
  Cache-Control: no-cache, no-store, must-revalidate

# Manifest and other root files — short cache so PWA metadata stays fresh.
/manifest.json
  Cache-Control: public, max-age=3600

# ── Private pages — tell search crawlers not to index these ────────────────────
# /portal: client-specific conversation portal (accessed via magic link — not meant for public)
# /conversation/*: creator-only conversation view
# /dashboard/*: creator dashboard — never public
# /settings/*: creator settings — never public
# /onboarding: creator onboarding — never public
/portal
  X-Robots-Tag: noindex, nofollow

/conversation/*
  X-Robots-Tag: noindex, nofollow

/dashboard/*
  X-Robots-Tag: noindex, nofollow

/settings/*
  X-Robots-Tag: noindex, nofollow

/onboarding
  X-Robots-Tag: noindex, nofollow
